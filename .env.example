# Channels — configure any combination, all active ones receive notifications

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Slack (Incoming Webhook)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Slack (Bot Token — use if you prefer a bot over a webhook)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_BOT_CHANNEL=#general

# Discord (Webhook)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ntfy (no account needed — just pick a topic name)
# NTFY_TOPIC=my-claude-notifications
# NTFY_SERVER=https://ntfy.sh  # optional, defaults to ntfy.sh; set to self-hosted URL

# macOS native notifications (macOS only)
# MACOS_NOTIFICATIONS=true

# Custom summary prompt (optional)
# CLAUDE_NOTIFY_PROMPT_FILE=/path/to/prompt.txt
# CLAUDE_NOTIFY_PROMPT=Summarize in one sentence: {{TOOL_CALLS}}

# LLM for AI summary — pick one provider:

# Option 1: Ollama (local, no API key)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Option 2: AWS Bedrock (uses AWS_ACCESS_KEY_ID/AWS_PROFILE from env)
# AWS_REGION=us-east-1

# Option 3: Google Vertex AI
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project
# ANTHROPIC_VERTEX_REGION=us-east5

# Option 4: OpenRouter (100+ models, one key)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-haiku-4-5  # optional, default shown

# Option 5: Anthropic API (direct)
# ANTHROPIC_API_KEY=sk-ant-...
