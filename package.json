{
  "name": "@eugene-bert/claude-hooks",
  "version": "0.1.6",
  "description": "Claude Code hooks — AI-summarized notifications to Telegram, Slack, and Discord",
  "type": "module",
  "bin": {
    "claude-hooks": "bin/cli.js"
  },
  "scripts": {
    "version": "node -e \"const fs=require('fs');const p=JSON.parse(fs.readFileSync('hooks/notify/package.json','utf8'));p.version=process.env.npm_new_version;fs.writeFileSync('hooks/notify/package.json',JSON.stringify(p,null,2)+'\\n');\" && git add hooks/notify/package.json"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.31.0",
    "@anthropic-ai/sdk": "^0.107.0",
    "@anthropic-ai/vertex-sdk": "^0.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "notifications",
    "telegram",
    "slack",
    "discord",
    "hooks",
    "ai"
  ],
  "author": "Eugene Bercowicz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eugene-bert/claude-hooks.git"
  },
  "homepage": "https://github.com/eugene-bert/claude-hooks#readme",
  "engines": {
    "node": ">=18"
  }
}
